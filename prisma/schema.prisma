generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)
  usages   TemplateUsage[]
}

model Template {
  id        Int       @id @default(autoincrement())
  title     String    @unique   
  template  String
  category  Category 
  tags      String[]
  author    String
  used      Int      @default(0)
  usages    TemplateUsage[]
}

model TemplateUsage {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  template   Template @relation(fields: [templateId], references: [id])
  templateId Int

  @@unique([userId, templateId])
}

enum Role {
  USER
  ADMIN
}

enum Category {
  GOOGLE_APPS      @map("Google Core/Consumer Apps")
  STAR_BANNER      @map("STAR/Banner")
  UH_ACCOUNT       @map("UH Account")
  DUO_MOBILE_MFA   @map("Duo Mobile/MFA")
  LAMAKU_LAULIMA   @map("Lamaku/Laulima LMS")
  NETWORK_PRINTING @map("Network/Printing")
  GENERAL_SUPPORT  @map("General Support")
  SITE_LICENSE     @map("Site License")
}