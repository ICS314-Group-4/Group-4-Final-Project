generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}

model Template {
  id        Int       @id @default(autoincrement())
  title     String
  template  String
  category  Category 
  tags      String[]
  author    String
  used      Int
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  excellent
  good
  fair
  poor
}

enum Category {
  account
  google_core
  star
  duo_mobile
  lamaku
  network
  general_support
  site_licensed_apps
}
